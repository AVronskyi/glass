      "Bash(node -e \"let s='';process.stdin.on\\('data',d=>s+=d\\);process.stdin.on\\('end',\\(\\)=>{const j=JSON.parse\\(s\\);const ds=j.data.filter\\(m=>m.id.includes\\('deepseek'\\)\\);console.log\\('DEEPSEEK MODELS:'\\);ds.forEach\\(m=>console.log\\('  '+m.id+'  \\('+m.name+'\\)'\\)\\);console.log\\(\\);console.log\\('TOTAL MODELS:',j.data.length\\);}\\)\")",
      "Bash(curl -sL 'https://openrouter.ai/api/v1/models' -o /tmp/or-models.json)",
      "Read(//tmp/**)",
